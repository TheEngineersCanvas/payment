{
  "name": "@tec/payment",
  "version": "0.1.0-RC1",
  "description": "Framework-agnostic payment abstraction SDK By TheEngineersCanvas",
  "license": "UNLICENSED",
  "author": "TheEngineersCanvas",
  "keywords": ["payment", "paystack", "typescript", "sdk", "nodejs", "webhook", "refund"],
  "repository": {
    "type": "git",
    "url": "https://github.com/TheEngineersCanvas/payment"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./nestjs": {
      "types": "./dist/adapters/nestjs/index.d.ts",
      "import": "./dist/adapters/nestjs/index.js",
      "require": "./dist/adapters/nestjs/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "tsup",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint --fix src/ tests/",
    "verify": "bash scripts/verify-build.sh",
    "prepublishOnly": "bun run verify"
  },
  "peerDependencies": {
    "@nestjs/common": "^11",
    "@nestjs/core": "^11",
    "rxjs": "^7"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    },
    "rxjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^11",
    "@nestjs/core": "^11",
    "@nestjs/platform-express": "^11",
    "@nestjs/testing": "^11",
    "@types/node": "^22",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitest/coverage-v8": "3.2.7",
    "eslint": "^10.7.0",
    "eslint-plugin-boundaries": "^7.0.2",
    "rxjs": "^7",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^3"
  }
}
